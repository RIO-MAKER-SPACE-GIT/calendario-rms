<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}{% if title != "Calendário — Rio Makerspace" %} — Calendário Rio Makerspace{% endif %}</title>
  <meta name="theme-color" content="#adf758">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="icon" href="/favicon.ico">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="stylesheet" href="/style.css">
  <!-- Vince analytics — placeholder. Trocar pelo domínio da sua instância quando ativar. -->
  <!-- <script defer data-domain="calendario.riomakerspace.com.br" src="https://vince.exemplo.com/script.js"></script> -->
  <script>
    (function () {
      const saved = localStorage.getItem('rms-theme');
      const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = saved ? saved : (systemDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  <style>
    /* Evita flash dos dois ícones de tema durante o carregamento do CSS */
    html[data-theme="light"] .theme-toggle .icon-moon,
    html[data-theme="dark"] .theme-toggle .icon-sun { display: none; }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="brand">
        <img src="https://www.riomakerspace.com.br/images/RMS-logo.png" alt="Rio Maker Space">
        <span class="brand-text">Rio <span>Maker Space</span></span>
      </a>

      <div class="header-actions">
        <button class="theme-toggle" type="button" aria-label="Alternar tema" title="Alternar tema">
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </button>

        <a class="header-link" href="https://www.riomakerspace.com.br/">
          Site principal
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      </div>
    </div>
  </header>

  <main>
    {% block content %}{{ content | safe }}{% endblock %}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-rule" aria-hidden="true"></div>
      <div class="footer-brand">Rio Maker Space</div>
      <p>
        Calls 1º e 3º sábado do mês, 14h-15h BRT.
        <a href="https://www.riomakerspace.com.br">www.riomakerspace.com.br</a>
      </p>
      <div class="footer-links">
        <a href="https://www.riomakerspace.com.br/projects">Projetos</a>
        <a href="https://www.riomakerspace.com.br/events">Eventos</a>
        <a href="https://www.riomakerspace.com.br/about">Sobre</a>
        <a href="mailto:contato@riomakerspace.com.br">Contato</a>
      </div>
    </div>
  </footer>

  <script>
    (function () {
      const toggle = document.querySelector('.theme-toggle');
      const html = document.documentElement;
      const media = window.matchMedia('(prefers-color-scheme: dark)');

      function getStoredTheme() {
        return localStorage.getItem('rms-theme');
      }

      function setStoredTheme(theme) {
        localStorage.setItem('rms-theme', theme);
      }

      function applyTheme(theme) {
        html.setAttribute('data-theme', theme);
      }

      function toggleTheme() {
        const current = html.getAttribute('data-theme') || 'light';
        const next = current === 'light' ? 'dark' : 'light';
        applyTheme(next);
        setStoredTheme(next);
      }

      if (toggle) {
        toggle.addEventListener('click', toggleTheme);
      }

      // Se o usuário nunca escolheu manualmente, acompanha o sistema.
      media.addEventListener('change', function (event) {
        if (!getStoredTheme()) {
          applyTheme(event.matches ? 'dark' : 'light');
        }
      });
    })();

    // —— Calendário runtime ———————————————————————————————
    // Sem framework. Lê data-attributes embarcados no build e:
    //   1. esconde ocorrências passadas,
    //   2. destaca a 1ª ocorrência futura como "Próxima",
    //   3. exibe badge "AO VIVO" quando uma ocorrência está rolando agora.
    // Sem fetch, sem rrule client-side. Reordena o que já está no HTML.
    (function () {
      const MESES = ['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
      const DIAS = ['dom','seg','ter','qua','qui','sex','sáb'];

      function fmtBRT(d) {
        const parts = new Intl.DateTimeFormat('pt-BR', {
          timeZone: 'America/Sao_Paulo',
          weekday: 'short', day: '2-digit', month: 'short', year: 'numeric',
          hour: '2-digit', minute: '2-digit', hour12: false,
        }).formatToParts(d);
        const get = (t) => parts.find((p) => p.type === t)?.value || '';
        const wd = get('weekday').replace('.','');
        const day = get('day');
        const mon = get('month').replace('.','').slice(0,3);
        const yr = get('year');
        const h = get('hour');
        const m = get('minute');
        return wd + ', ' + day + ' ' + mon + ' ' + yr + ' — ' + h + 'h' + m;
      }

      function parseIso(s) { return new Date(s); }

      // Atualiza o <time> com a próxima ocorrência real, dentro de cards/headers.
      function atualizaVisivel() {
        const agora = Date.now();
        document.querySelectorAll('[data-ocorrencia-visivel]').forEach(function (el) {
          // Usa o JSON embarcado próximo, se houver, pra escolher a próxima real.
          const card = el.closest('[data-evento-card]') || el.closest('.evento-pagina');
          let ocorr = null;
          if (card) {
            const script = card.querySelector('script[data-ocorrencias]');
            if (script) {
              try {
                const lista = JSON.parse(script.textContent);
                ocorr = (lista || []).find(function (o) {
                  return parseIso(o.fim_iso || o.iso).getTime() >= agora;
                }) || lista[0];
              } catch (_e) {}
            }
          }
          if (!ocorr) return;
          const inicio = parseIso(ocorr.iso);
          const fim = parseIso(ocorr.fim_iso || ocorr.iso);
          el.setAttribute('datetime', ocorr.iso);
          el.setAttribute('data-inicio', ocorr.iso);
          el.setAttribute('data-fim', ocorr.fim_iso || ocorr.iso);
          el.textContent = fmtBRT(inicio);
          // Badge AO VIVO no card/header
          if (agora >= inicio.getTime() && agora < fim.getTime()) {
            el.classList.add('ao-vivo');
            let badge = el.parentNode.querySelector('.badge-ao-vivo');
            if (!badge) {
              badge = document.createElement('span');
              badge.className = 'badge-ao-vivo';
              badge.textContent = 'AO VIVO';
              el.parentNode.insertBefore(badge, el.nextSibling);
            }
          }
        });
      }

      // Listas de excecoes/exdates: só esconde passadas em runtime.
      // (O "Próximo evento" é herói separado, não há mais lista de comuns pra marcar.)
      function atualizaLista() {
        const agora = Date.now();
        document.querySelectorAll('[data-ocorrencias-lista]').forEach(function (ul) {
          ul.querySelectorAll('li[data-ocorrencia]').forEach(function (li) {
            const inicio = parseIso(li.getAttribute('data-inicio'));
            const fim = parseIso(li.getAttribute('data-fim'));
            // Remove badges AO VIVO de runs anteriores.
            li.querySelector('.badge-ao-vivo')?.remove();
            if (fim.getTime() < agora) {
              li.style.display = 'none';
              return;
            }
            li.style.display = '';
            // AO VIVO: só pra lista de especiais (excecoes).
            if (agora >= inicio.getTime() && agora < fim.getTime() && ul.closest('.eventos-especiais')) {
              const badge = document.createElement('span');
              badge.className = 'badge-ao-vivo';
              badge.textContent = 'AO VIVO';
              li.appendChild(badge);
            }
          });
        });
      }

      function tick() {
        try { atualizaVisivel(); } catch (_e) {}
        try { atualizaLista(); } catch (_e) {}
      }
      tick();
      // Recheca a cada minuto (badge AO VIVO precisa virar/ perder).
      setInterval(tick, 60 * 1000);
    })();
  </script>
</body>
</html>
